# WhatsApp destination number \u2014 digits only, no + or spaces
# Format: country code + number (Spain: 34 + 9 digits)
VITE_WHATSAPP_NUMBER=34XXXXXXXXX

# Human-readable phone number shown in the Contact section
VITE_PHONE_DISPLAY=+34 XXX XX XX XX

# Contact email shown in Contact section and Privacy Policy
VITE_CONTACT_EMAIL=gymdenia@gmail.com
